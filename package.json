{
  "dependencies": {
    "@llamaindex/llama-cloud": "^2.4.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/mapped-types": "*"
  },
  "name": "rag",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "backend",
    "web"
  ],
  "scripts": {
    "dev:backend": "yarn workspace @rag/backend start:dev",
    "dev:web": "yarn workspace @rag/web dev",
    "docker-be-up-dev": "docker compose -f backend/docker-compose.yml --env-file backend/.env up",
    "docker-be-down": "docker compose -f backend/docker-compose.yml down",
    "docker-llm-up": "docker compose -f llm/docker-compose-llm.yml up",
    "docker-llm-down": "docker compose -f llm/docker-compose-llm.yml down",
    "dev": "concurrently \"yarn dev:backend\" \"yarn dev:web\"",
    "prisma-studio": "cd backend && npx prisma studio",
    "reset-db": "cd backend && npx prisma migrate reset",
    "build:backend": "yarn workspace @rag/backend build",
    "build:web": "yarn workspace @rag/web build",
    "build": "yarn build:backend && yarn build:web",
    "install-be": "yarn workspace @rag/backend add",
    "install-web": "yarn workspace @raq/web add",
    "lint": "yarn workspaces run lint",
    "test": "yarn workspace @rag/backend test"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "lightningcss-linux-x64-gnu": "^1.32.0"
  },
  "keywords": [
    "nestjs",
    "rag"
  ],
  "author": "hieulm",
  "license": "ISC",
  "description": "RAG Personal learning project"
}
